// YARA-L 2.0 Sample Rules
// Realistic rules from https://github.com/chronicle/detection-rules (Apache 2.0, Google LLC)
// plus synthetic coverage for all token types defined in the lexer.

/* -----------------------------------------------------------------------
   Realistic rules from the official Google chronicle/detection-rules repo
   ----------------------------------------------------------------------- */

rule geoip_user_login_from_multiple_countries {

  meta:
    author = "Google Cloud Security"
    description = "Detect multiple user logins from multiple states or countries using Chronicle GeoIP enrichment."
    rule_id = "mr_3fa832e4-1ac0-42cd-9f0a-357d6b8fb12f"
    rule_name = "GeoIP User Login From Multiple States Or Countries"
    type = "alert"
    data_source = "microsoft ad, azure ad, okta, aws cloudtrail, google scc"
    tags = "geoip enrichment"
    severity = "Low"
    priority = "Low"

  events:
    $login.metadata.event_type = "USER_LOGIN"
    $login.security_result.action = "ALLOW"
    $login.principal.ip_geo_artifact.location.country_or_region != ""
    $login.principal.ip_geo_artifact.location.country_or_region = $country
    $login.principal.ip_geo_artifact.location.state = $state
    $login.metadata.product_name = $product
    $login.target.user.userid = $user

  match:
    $user, $product over 1h

  outcome:
    $risk_score = 35
    $event_count = count_distinct($login.metadata.id)
    $dc_state = count_distinct($login.principal.ip_geo_artifact.location.state)
    $array_state = array_distinct($login.principal.ip_geo_artifact.location.state)
    $dc_country = count_distinct($login.principal.ip_geo_artifact.location.country_or_region)
    $array_country = array_distinct($login.principal.ip_geo_artifact.location.country_or_region)
    $array_asn = array_distinct($login.principal.ip_geo_artifact.network.asn)
    $principal_hostname = array_distinct($login.principal.hostname)
    $principal_ip = array_distinct($login.principal.ip)
    $target_hostname = array_distinct($login.target.hostname)
    $target_user_userid = array_distinct($login.target.user.userid)

  condition:
    #country >= 1 and #state >= 2
}

rule logins_from_terminated_employees {

  meta:
    author = "Google Cloud Security"
    description = "Allowed Logins from Terminated Employees"
    rule_id = "mr_69178541-285b-45cb-b723-e2b5d88f22d3"
    assumptions = "Requires a context data source such as AzureAD or Workday."
    type = "alert"
    tags = "user enrichment"
    tactic = "TA0001"
    technique = "T1078"
    severity = "Medium"
    priority = "Medium"

  events:
    $login.metadata.event_type = "USER_LOGIN"
    $login.security_result.action = "ALLOW"
    $login.target.user.userid = $user
    $login.target.user.termination_date.seconds > 0
    $login.target.user.termination_date.seconds < $login.metadata.event_timestamp.seconds

  match:
    $user over 1d

  outcome:
    $risk_score = 65
    $event_count = count_distinct($login.metadata.id)
    $employee_last_login = max($login.target.user.termination_date.seconds)
    $total_distinct_ips = count_distinct($login.principal.ip)
    $principal_hostname = array_distinct($login.principal.hostname)
    $target_hostname = array_distinct($login.target.hostname)
    $principal_user_userid = array_distinct($login.principal.user.userid)
    //$target_user_userid = array_distinct($login.target.user.userid)
    $target_url = array_distinct($login.target.url)

  condition:
    $login
}

rule dns_query_to_recently_created_domain {

  meta:
    author = "Google Cloud Security"
    description = "DNS query to a recently created domain"
    rule_id = "mr_a5cff3f1-8092-48a0-b4a3-f3f856299474"
    type = "alert"
    tags = "whois"
    data_source = "microsoft sysmon"
    severity = "Low"
    priority = "Low"

  events:
    $dns.metadata.event_type = "NETWORK_DNS"
    $dns.network.dns.questions.name = $dns_query
    $dns.principal.user.userid = $user

    // whois data provided by GCTI
    $whois.graph.entity.hostname = $dns_query
    $whois.graph.metadata.entity_type = "DOMAIN_NAME"
    $whois.graph.metadata.vendor_name = "WHOIS"
    $whois.graph.entity.domain.creation_time.seconds > 0
    // domain was created in the last 30 days
    2592000 > timestamp.current_seconds() - $whois.graph.entity.domain.creation_time.seconds

  match:
    $user over 1h

  outcome:
    $risk_score = max(35)
    $event_count = count_distinct($dns.metadata.id)
    $network_dns_questions_name = array_distinct($dns.network.dns.questions.name)
    $network_dns_answers_data = array_distinct($dns.network.dns.answers.data)
    $principal_ip = array_distinct($dns.principal.ip)
    $target_ip = array_distinct($dns.target.ip)
    $principal_process_pid = array_distinct($dns.principal.process.pid)
    $principal_process_file_full_path = array_distinct($dns.principal.process.file.full_path)
    $principal_process_command_line = array_distinct($dns.principal.process.command_line)
    $principal_process_file_sha256 = array_distinct($dns.principal.process.file.sha256)

  condition:
    $dns and $whois
}

rule network_traffic_to_specific_country {

  meta:
    author = "Google Cloud Security"
    description = "Identify network traffic based on target country"
    rule_id = "mr_f1ab5184-771f-48dc-82e6-11a72632fcd5"
    type = "alert"
    tags = "geoip enrichment"
    severity = "Low"
    priority = "Low"

  events:
    $network.metadata.event_type = "NETWORK_CONNECTION"
    // Specify a country of interest to monitor
    $network.target.ip_geo_artifact.location.country_or_region = "France" nocase
    $network.target.ip = $ip

  match:
    $ip over 30m

  outcome:
    $risk_score = max(35)
    $event_count = count_distinct($network.metadata.id)
    $principal_ip = array_distinct($network.principal.ip)
    $principal_process_pid = array_distinct($network.principal.process.pid)
    $principal_process_command_line = array_distinct($network.principal.process.command_line)
    $principal_process_file_sha256 = array_distinct($network.principal.process.file.sha256)
    $principal_process_file_full_path = array_distinct($network.principal.process.file.full_path)
    $principal_process_product_specific_process_id = array_distinct($network.principal.process.product_specific_process_id)
    $principal_process_parent_process_product_specific_process_id = array_distinct($network.principal.process.parent_process.product_specific_process_id)
    $principal_user_userid = array_distinct($network.principal.user.userid)
    $target_user_userid = array_distinct($network.target.user.userid)

  condition:
    $network
}

/* -----------------------------------------------------------------------
   Synthetic coverage rules – exercise token types not in the rules above
   ----------------------------------------------------------------------- */

// ── Operator keywords: or, not, nocase, any, all, in, regex, cidr ──

rule operator_keywords_coverage {
  meta:
    description = "Covers operator keyword tokens"
  events:
    $e.metadata.event_type = "NETWORK_DNS" or $e.metadata.event_type = "NETWORK_DHCP"
    not $e.principal.hostname = "internal-host" nocase
    any $e.principal.ip != "10.0.0.1"
    all $e.target.ip != "192.168.1.1"
    $e.principal.ip in cidr %trusted_networks
    $e.principal.hostname in regex %allowlist nocase
    $e.principal.hostname in %string_reference_list
  match:
    $user over 5m
  condition:
    $e and #e > 0
}

// ── Time windows: by (tumbling), over…after (sliding) ──

rule tumbling_window {
  meta:
    description = "Tumbling window: match $var by <duration>"
  events:
    $login.metadata.event_type = "USER_LOGIN"
    $file.metadata.event_type = "FILE_MODIFICATION"
    $login.principal.user.userid = $user
    $file.principal.user.userid = $user
  match:
    $user by 30m
  condition:
    $login and $file
}

rule sliding_window_after {
  meta:
    description = "Covers sliding window with after keyword"
  events:
    $login.metadata.event_type = "USER_LOGIN"
    $exec.metadata.event_type = "PROCESS_LAUNCH"
    $login.principal.user.userid = $user
    $exec.principal.user.userid = $user
  match:
    $user over 1h after $login
  condition:
    $login and $exec
}

// ── Boolean / null constants, string and regex literals ──

rule string_and_constant_coverage {
  meta:
    description = "Covers string literals, escape sequences, backtick strings, regex literals, and constants"
    note = "Escape sequences: \n \t \r \\ \""
  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    $e.principal.process.command_line = /cmd\.exe/
    re.regex($e.principal.process.command_line, `powershell\.exe`) nocase
    $e.principal.hostname != "trusted-host"
    $e.principal.user.userid != null
  outcome:
    $flag = true
    $other = false
    $score = 0.75
  condition:
    $e
}

// ── Built-in functions: re.*, math.*, net.*, hash.*, cast.*, timestamp.* ──

rule builtin_functions_coverage {
  meta:
    description = "Covers built-in function namespaces"
  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    net.ip_in_range_cidr($e.principal.ip, "192.0.2.0/24")
    $e.network.sent_bytes > 1048576
  outcome:
    $cmd_arg = re.capture($e.principal.process.command_line, `(?i)-enc\s+(\S+)`)
    $sanitized = re.replace($e.principal.process.command_line, `\s+`, " ")
    $sha = hash.sha256($e.target.file.full_path)
    $b64 = bytes.to_base64($e.target.file.content)
    $as_int = cast.as_int($e.about.labels.value)
    $as_str = cast.as_string($e.network.sent_bytes)
    $abs_val = math.abs($e.network.sent_bytes)
    $log_val = math.log($e.network.sent_bytes)
    $dist = math.geo_distance(37.7749, -122.4194, 40.7128, -74.0060)
    $cur_secs = timestamp.current_seconds()
    $hour = timestamp.get_hour($e.metadata.event_timestamp.seconds, "UTC")
    $date_str = timestamp.get_date($e.metadata.event_timestamp.seconds, "America/New_York")
  condition:
    $e
}

/* -----------------------------------------------------------------------
   Dashboard queries – no rule{} wrapper; use order:/limit:/stage sections
   Source: https://docs.cloud.google.com/chronicle/docs/reference/sample-yaral-for-native-dashboard
   ----------------------------------------------------------------------- */

// ── USER_LOGIN by status (bare field paths, order, limit) ──
metadata.event_type = "USER_LOGIN"
$security_result = security_result.action
$security_result = "BLOCK" OR $security_result = "ALLOW"

match:
    $security_result

outcome:
    $event_count = count_distinct(metadata.id)

// ── Successful sign-ins over time (order asc/desc) ──
metadata.event_type = "USER_LOGIN"
$security_result = security_result.action
$security_result = "ALLOW"
$date = timestamp.get_date(metadata.event_timestamp.seconds, "America/Los_Angeles")

match:
    $security_result, $date

outcome:
    $event_count = count_distinct(metadata.id)

order:
    $date desc

// ── User sign-ins by country ──
metadata.event_type = "USER_LOGIN"
$country = principal.location.country_or_region
$country != ""

match:
    $country

outcome:
    $event_count = count_distinct(metadata.id)

order:
    $event_count desc

// ── Top 10 rule names by detection count (limit section) ──
$rule_name = detection.detection.rule_name

match:
    $rule_name

outcome:
    $count = count_distinct(detection.id)

order:
    $count desc

limit:
    10

// ── Top IPs across roles using group() ──
$ip = group(detection.collection_elements.references.event.principal.ip, detection.collection_elements.references.event.target.ip, detection.collection_elements.references.event.src.ip)

$ip != ""

match:
    $ip

outcome:
    $count = count(detection.id)

order:
    $count desc

limit:
    10

// ── stage construct: mean time to close cases ──
stage stage1 {
  $case_id = case_history.case_response_platform_info.case_id

  match:
    $case_id

  outcome:
    $case_close_time = max(if(case_history.case_activity = "CLOSE_CASE", case_history.event_time.seconds, 0))
    $status = array_distinct(case_history.case_activity)
    $TTC = $case_close_time - min(case_history.event_time.seconds)

  condition:
    arrays.contains($status, "CREATE_CASE") and arrays.contains($status, "CLOSE_CASE")
}

outcome:
  $case_count = count($stage1.case_id)
  $MTTC = (math.round(avg($stage1.TTC) / 60))

// ── Ingestion metrics (AND uppercase, sum with if) ──
$Log_Type = ingestion.log_type

match:
    $Log_Type

outcome:
    $Total_Size_Bytes = sum(if(ingestion.component = "Ingestion API", ingestion.log_volume, 0))
    $Total_Logs = sum(if(ingestion.component = "Ingestion API", ingestion.log_count, 0))
    $Normalized = sum(if(ingestion.component = "Normalizer" AND ingestion.state = "validated", ingestion.event_count, 0))
    $Parse_Errors = sum(if(ingestion.component = "Normalizer" AND ingestion.state = "failed_parsing", ingestion.log_count, 0))

order:
    $Total_Size_Bytes desc

// ── match with bare field path (no $ prefix) ──
match:
    case.status

outcome:
    $count = count(case.name)

// ── match: field by time granularity ──
$rule_author = rules.author

match:
    $rule_author by day

outcome:
    $count_of_rules = count(rules.name)

order:
    $count_of_rules desc

// ── dedup: deduplicate results by a field ──
metadata.event_type = "USER_LOGIN"
$user = principal.user.userid

match:
    $user

outcome:
    $event_count = count_distinct(metadata.id)

dedup:
    principal.ip

order:
    $event_count desc

// ── select / unselect: choose outcome columns to display ──
metadata.event_type = "NETWORK_CONNECTION"
$src = principal.ip
$dst = target.ip

match:
    $src, $dst

outcome:
    $bytes = sum(network.sent_bytes)
    $connections = count(metadata.id)

select:
    $src
    $dst
    $bytes

unselect:
    $connections

order:
    $bytes desc

/* ----------------------------------------------------------------------- */

// ── if() expression and suppression_window option ──

rule if_expression_and_options {
  meta:
    description = "Covers if() expression and options section"
  events:
    $e.metadata.event_type = "USER_LOGIN"
    $user = $e.principal.user.userid
  match:
    $user over 10m
  outcome:
    $count = count($e.metadata.id)
    $risk_score = if($count > 20, 90, if($count > 10, 60, 30))
    $suppression_key = $user
  options:
    allow_zero_values = true
    suppression_window = 1h
  condition:
    $e
}

// ── metrics.* functions (Risk Analytics) ──

rule metrics_functions_demo {
  meta:
    description = "Demonstrates metrics.* functions for Risk Analytics rules"
  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.principal.user.userid = $user
  match:
    $user over 7d
  outcome:
    $bytes_out = max(metrics.network_bytes_outbound(period:1d, window:30d))
    $bytes_in  = max(metrics.network_bytes_inbound(period:1d, window:30d))
    $bytes_tot = max(metrics.network_bytes_total(period:1d, window:30d))
    $auth_ok   = max(metrics.auth_attempts_success(period:1d, window:30d))
    $auth_fail = max(metrics.auth_attempts_fail(period:1d, window:30d))
    $auth_tot  = max(metrics.auth_attempts_total(period:1d, window:30d))
    $dns_ok    = max(metrics.dns_queries_success(period:1d, window:30d))
    $dns_fail  = max(metrics.dns_queries_fail(period:1d, window:30d))
    $dns_tot   = max(metrics.dns_queries_total(period:1d, window:30d))
    $dns_bytes = max(metrics.dns_bytes_outbound(period:1d, window:30d))
    $http_ok   = max(metrics.http_queries_success(period:1d, window:30d))
    $http_fail = max(metrics.http_queries_fail(period:1d, window:30d))
    $http_tot  = max(metrics.http_queries_total(period:1d, window:30d))
    $file_ok   = max(metrics.file_executions_success(period:1d, window:30d))
    $file_fail = max(metrics.file_executions_fail(period:1d, window:30d))
    $file_tot  = max(metrics.file_executions_total(period:1d, window:30d))
    $res_ok    = max(metrics.resource_creation_success(period:1d, window:30d))
    $res_tot   = max(metrics.resource_creation_total(period:1d, window:30d))
    $res_del   = max(metrics.resource_deletion_success(period:1d, window:30d))
    $res_rfail = max(metrics.resource_read_fail(period:1d, window:30d))
    $res_rok   = max(metrics.resource_read_success(period:1d, window:30d))
    $alerts    = max(metrics.alert_event_name_count(period:1d, window:30d))
  condition:
    $e
}
